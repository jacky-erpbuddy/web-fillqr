generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Models
// ============================================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  street    String?
  zip       String?
  city      String?
  email     String?
  phone     String?
  logoPath  String?  @map("logo_path")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenantApps TenantApp[]
  appUsers   AppUser[]

  @@map("tbl_tenants")
}

model App {
  id   String @id @default(cuid())
  key  String @unique
  name String

  tenantApps TenantApp[]

  @@map("tbl_apps")
}

model TenantApp {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  appId        String   @map("app_id")
  slug         String   @unique
  isEnabled    Boolean  @default(true) @map("is_enabled")
  settingsJson Json     @default("{}") @map("settings_json")
  brandingJson Json     @default("{}") @map("branding_json")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app    App    @relation(fields: [appId], references: [id], onDelete: Restrict)

  @@map("tbl_tenant_apps")
}

model AppUser {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  email           String    @unique
  passwordHash    String    @map("password_hash")
  inviteToken     String?   @unique @map("invite_token")
  inviteExpiresAt DateTime? @map("invite_expires_at")
  resetToken      String?   @unique @map("reset_token")
  resetExpiresAt  DateTime? @map("reset_expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tbl_app_users")
}
