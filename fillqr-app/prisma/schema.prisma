generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Models
// ============================================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  street    String?
  zip       String?
  city      String?
  email     String?
  phone     String?
  logoPath  String?  @map("logo_path")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenantApps      TenantApp[]
  appUsers        AppUser[]
  members         Member[]
  membershipTypes MembershipType[]
  departments     Department[]
  sepaMandates    SepaMandate[]
  emailTemplates  EmailTemplate[]

  @@map("tbl_tenants")
}

model App {
  id   String @id @default(cuid())
  key  String @unique
  name String

  tenantApps TenantApp[]

  @@map("tbl_apps")
}

model TenantApp {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  appId        String   @map("app_id")
  slug         String   @unique
  isEnabled    Boolean  @default(true) @map("is_enabled")
  settingsJson Json     @default("{}") @map("settings_json")
  brandingJson Json     @default("{}") @map("branding_json")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app    App    @relation(fields: [appId], references: [id], onDelete: Restrict)

  @@map("tbl_tenant_apps")
}

model AppUser {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  email           String    @unique
  passwordHash    String    @map("password_hash")
  inviteToken     String?   @unique @map("invite_token")
  inviteExpiresAt DateTime? @map("invite_expires_at")
  resetToken      String?   @unique @map("reset_token")
  resetExpiresAt  DateTime? @map("reset_expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tbl_app_users")
}

// ============================================================
// VereinsBuddy Models
// ============================================================

model MembershipType {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  fee       Decimal
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members Member[]

  @@map("tbl_membership_types")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  extraFee  Decimal  @default(0) @map("extra_fee")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members MemberDepartment[]

  @@map("tbl_departments")
}

model Member {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  memberNo         Int?      @map("member_no")
  status           String    @default("eingegangen")
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  email            String
  phone            String?
  street           String?
  zip              String?
  city             String?
  birthdate        DateTime?
  entryDate        DateTime? @map("entry_date")
  membershipTypeId String?   @map("membership_type_id")
  paymentInterval  String?   @map("payment_interval")
  paymentMethod    String?   @map("payment_method")
  photoPath        String?   @map("photo_path")
  notes            String?
  statusHistory    Json?     @map("status_history")
  photoConsent     Boolean?  @map("photo_consent")
  newsletter       Boolean?
  volunteer        Boolean?
  donation         Decimal?
  referredBy       String?   @map("referred_by")
  familyGroupId    String?   @map("family_group_id")
  familyHead       Boolean?  @map("family_head")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membershipType MembershipType?     @relation(fields: [membershipTypeId], references: [id], onDelete: SetNull)
  departments    MemberDepartment[]
  guardians      Guardian[]
  sepaMandate    SepaMandate?

  @@unique([tenantId, memberNo])
  @@index([tenantId, status])
  @@map("tbl_members")
}

model Guardian {
  id        String   @id @default(cuid())
  memberId  String   @map("member_id")
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String
  phone     String?
  street    String?
  zip       String?
  city      String?
  relation  String?
  createdAt DateTime @default(now()) @map("created_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("tbl_guardians")
}

model SepaMandate {
  id            String    @id @default(cuid())
  memberId      String    @unique @map("member_id")
  tenantId      String    @map("tenant_id")
  accountHolder String    @map("account_holder")
  iban          String
  bic           String?
  mandateRef    String    @unique @map("mandate_ref")
  status        String    @default("active")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastUsed      DateTime? @map("last_used")

  member Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tbl_sepa_mandates")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  appKey      String   @map("app_key")
  templateKey String   @map("template_key")
  subject     String
  body        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, appKey, templateKey])
  @@map("tbl_email_templates")
}

model MemberDepartment {
  memberId     String @map("member_id")
  departmentId String @map("department_id")

  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([memberId, departmentId])
  @@map("tbl_member_departments")
}
