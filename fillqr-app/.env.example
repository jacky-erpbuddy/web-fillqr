# fillQR — Environment Variables
# Copy to .env and fill in real values
# IMPORTANT: .env must NOT be committed to git!

# --- Database ---
# Docker-Netzwerk (Compose):
DATABASE_URL=postgresql://fillqr_app:PASSWORD@fillqr-postgres:5432/fillqr
# Lokal via SSH-Tunnel (Port 5433):
# DATABASE_URL=postgresql://fillqr_app:PASSWORD@localhost:5433/fillqr

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Tenant ---
# Base-Domain fuer Subdomain-Erkennung
BASE_DOMAIN=fillqr.de
# Lokal: BASE_DOMAIN=localhost

# --- Session ---
# Mindestens 32 Zeichen, zufaellig generiert
SESSION_SECRET=CHANGE_ME_MINDESTENS_32_ZEICHEN_LANG

# --- Turnstile (Spam-Schutz) ---
# Test-Keys fuer Entwicklung: Site=1x00000000000000000000AA, Secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- SMTP (E-Mail-Versand) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@fillqr.de
SMTP_PASS=
SMTP_FROM=noreply@fillqr.de

# --- Betreiber-Panel (admin.fillqr.de) ---
# Klartext-Passwort (kein bcrypt noetig — hinter IP-Whitelist + Basic Auth)
BETREIBER_PASSWORD=

# --- Demo-Benachrichtigung (optional) ---
# n8n Webhook fuer Telegram-Notification bei Demo-Submissions
N8N_NOTIFY_URL=
