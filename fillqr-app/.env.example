# fillQR — Environment Variables
# Copy to .env and fill in real values
# IMPORTANT: .env must NOT be committed to git!

# --- Database ---
# Docker-Netzwerk (Compose):
DATABASE_URL=postgresql://fillqr_app:PASSWORD@fillqr-postgres:5432/fillqr
# Lokal via SSH-Tunnel (Port 5433):
# DATABASE_URL=postgresql://fillqr_app:PASSWORD@localhost:5433/fillqr

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Tenant ---
# Base-Domain fuer Subdomain-Erkennung
BASE_DOMAIN=fillqr.de
# Lokal: BASE_DOMAIN=localhost

# --- Session ---
# Mindestens 32 Zeichen, zufaellig generiert
SESSION_SECRET=CHANGE_ME_MINDESTENS_32_ZEICHEN_LANG

# --- Betreiber-Panel (admin.fillqr.de) ---
# bcrypt-Hash des Betreiber-Passworts (nur Jacky)
# Generieren: node -e "const b=require('bcrypt');b.hash('mein-passwort',10).then(h=>console.log(h))"
BETREIBER_PASSWORD_HASH=
