# fillQR — Environment Variables
# Copy to .env and fill in real values
# IMPORTANT: .env must NOT be committed to git!

# --- Database ---
# Docker-Netzwerk (Compose):
DATABASE_URL=postgresql://fillqr_app:PASSWORD@fillqr-postgres:5432/fillqr
# Lokal via SSH-Tunnel (Port 5433):
# DATABASE_URL=postgresql://fillqr_app:PASSWORD@localhost:5433/fillqr

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
